{
  "id": "scenario_1",
  "title": "Drought Response",
  "description": "Manage the Millbrook reservoir's extraction rate over 8 operating days as a dry spell approaches and recovers. Balance supply against long-term reservoir health.",
  "parameters": {
    "treatment_efficiency": 0.80,
    "daily_demand_mgd": 4.0,
    "reservoir_min_mgd": 20,
    "reservoir_max_mgd": 100,
    "reservoir_start_mgd": 60
  },
  "extraction_options_mgd": [2, 4, 6, 8],
  "nodes": [
    {
      "index": 0,
      "day": 1,
      "rainfall_mgd": 3.0,
      "narrative": "Normal operations. The reservoir is at 60 MG. Set today's extraction rate.",
      "alert": null
    },
    {
      "index": 1,
      "day": 2,
      "rainfall_mgd": 3.0,
      "narrative": "Conditions remain normal. Reservoir levels are stable.",
      "alert": null
    },
    {
      "index": 2,
      "day": 3,
      "rainfall_mgd": 3.0,
      "narrative": "A weather advisory warns of a dry spell beginning next week.",
      "alert": "forecast_drought"
    },
    {
      "index": 3,
      "day": 4,
      "rainfall_mgd": 1.0,
      "narrative": "The drought has begun. Rainfall has dropped sharply.",
      "alert": "drought_active"
    },
    {
      "index": 4,
      "day": 5,
      "rainfall_mgd": 1.0,
      "narrative": "Drought conditions persist. The reservoir trend is now visible on your dashboard.",
      "alert": "drought_active"
    },
    {
      "index": 5,
      "day": 6,
      "rainfall_mgd": 0.5,
      "narrative": "Drought conditions are worsening. A red alert will trigger if the reservoir falls below 35 MG.",
      "alert": "reservoir_critical_if_below_35"
    },
    {
      "index": 6,
      "day": 7,
      "rainfall_mgd": 2.0,
      "narrative": "Rainfall is beginning to recover.",
      "alert": null
    },
    {
      "index": 7,
      "day": 8,
      "rainfall_mgd": 3.0,
      "narrative": "Normal rainfall has returned. This is the final operating day of the scenario.",
      "alert": null
    }
  ],
  "ecd": {
    "competency_elements": [
      "causal_reasoning",
      "feedback_recognition",
      "time_delay_awareness",
      "multivariable_synthesis"
    ],
    "evidence_rules": [
      { "element": "feedback_recognition", "rule": "extraction_at_node_lte", "node_index": 3, "threshold": 2, "score": "high" },
      { "element": "time_delay_awareness", "rule": "extraction_at_node_lte", "node_index": 2, "threshold": 2, "score": "high" }
    ]
  },
  "debrief": {
    "causal_map": {
      "nodes": ["rainfall", "reservoir_level", "extraction_rate", "treated_output", "demand", "supply_deficit"],
      "pre_placed_edges": [
        { "from": "treated_output", "to": "supply_deficit", "polarity": "-" }
      ],
      "target_edges": [
        { "from": "rainfall", "to": "reservoir_level", "polarity": "+" },
        { "from": "extraction_rate", "to": "reservoir_level", "polarity": "-" },
        { "from": "extraction_rate", "to": "treated_output", "polarity": "+" },
        { "from": "reservoir_level", "to": "extraction_rate", "polarity": "+" }
      ]
    },
    "reflection_prompts": [
      { "prompt_id": "unexpected_outcome", "text": "Describe one outcome that surprised you and explain what caused it." },
      { "prompt_id": "surprising_loop", "text": "Which feedback relationship most influenced the reservoir level over the 8 days?" },
      { "prompt_id": "different_decision", "text": "If you could go back to Day 3, what would you do differently and why?" }
    ]
  }
}