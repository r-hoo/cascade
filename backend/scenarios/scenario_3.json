{
  "id": "scenario_3",
  "title": "Compounding Pressures",
  "description": "Three zones, two water sources, one drought. Zone B demand is growing. Zone C is a hospital that cannot lose supply for two consecutive days. A groundwater aquifer supplements your reservoir automatically — but over-draw it and it won't recover in time.",
  "parameters": {
    "treatment_efficiency":       0.80,
