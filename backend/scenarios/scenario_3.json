    "zone_b_demand_max_mgd":      4.0,
    "zone_b_growth_per_step":     0.20,
    "aquifer_start_mgd":          50,
    "aquifer_max_mgd":            50,
    "aquifer_draw_rate":          2.0,
    "aquifer_draw_threshold":     30,
    "aquifer_recharge_normal":    1.0,
    "aquifer_recharge_stressed":  0.25,
    "aquifer_stress_threshold":   10,
    "reservoir_start_mgd":        65,
    "reservoir_max_mgd":          100,
    "reservoir_min_mgd":          20
  },
  "extraction_options_mgd": [3, 5, 7, 9],
  "nodes": [
    {
      "index": 0, "day": 1, "rainfall_mgd": 2.5,
      "narrative": "Three zones are now online. Zone A residential demand is stable at 2.0 MG/day. Zone B industrial is at 2.0 MG/day and growing. Zone C hospital requires uninterrupted supply at 1.0 MG/day. A groundwater aquifer buffer backs up the main reservoir automatically if levels drop below 30 MG.",
      "alert": null
    },
    {
      "index": 1, "day": 2, "rainfall_mgd": 2.5,
      "narrative": "Normal operations. Zone B demand grows if supply is being met.",
      "alert": null
    },
    {
      "index": 2, "day": 3, "rainfall_mgd": 2.0,
      "narrative": "Rainfall beginning to decline. Zone B demand has been rising. Plan ahead.",
      "alert": "rainfall_declining"
    },
    {
      "index": 3, "day": 4, "rainfall_mgd": 1.5,
      "narrative": "Drought conditions developing. The main reservoir is trending downward.",
      "alert": "drought_developing"
    },
    {
      "index": 4, "day": 5, "rainfall_mgd": 1.0,
      "narrative": "Drought active. If the main reservoir drops below 30 MG, the aquifer will begin drawing automatically at 2.0 MG/day to supplement treatment.",
      "alert": "drought_active"
    },
    {
      "index": 5, "day": 6, "rainfall_mgd": 0.5,
      "narrative": "Severe drought. If the aquifer is drawing, monitor its level carefully — below 10 MG it recharges at only 0.25 MG/day instead of 1.0 MG/day.",
      "alert": "drought_severe"
    },
    {
      "index": 6, "day": 7, "rainfall_mgd": 0.5,
      "narrative": "Drought continues. Aquifer stress is a risk if the buffer has been heavily drawn. Zone C supply must be maintained.",
      "alert": "drought_severe"
    },
    {
      "index": 7, "day": 8, "rainfall_mgd": 1.0,
      "narrative": "Slight rainfall recovery. Check whether the aquifer is recovering or still stressed.",
      "alert": null
    },
    {
      "index": 8, "day": 9, "rainfall_mgd": 2.0,
      "narrative": "Rainfall recovering steadily. Assess whether extraction can increase to meet Zone B demand.",
      "alert": null
    },
    {
      "index": 9, "day": 10, "rainfall_mgd": 2.5,
      "narrative": "Normal rainfall has returned. This is the final operating day. Assess the system's overall stability.",
      "alert": null
    }
  ],
